# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto eol=lf

# Force LF for source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.svg  text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.ico  binary
